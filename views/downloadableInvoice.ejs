<!DOCTYPE html>
<html lang="en">
  <head>
    <style>
      body {
        font-family: Arial, sans-serif;
        max-width: 1000px;
        margin: 20px auto;

        padding: 20px;
      }
      .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 80px;
        margin-left: -20px;
      }
      .logo {
        position: relative;
        width: 180px;
        height: 180px;
        /* border: 1px solid red; */
      }
      .logo img {
        height: auto;
        width: 180px;
      }

      .receipt-number {
        /* border: 1px solid #000; */
        padding: 5px 18px;
        font-size: 0.9;
      }
      .org-details {
        flex-grow: 1;
        margin: 0 20px;
      }
      .reg-number {
        font-size: 0.7em;
        color: #444;
      }
      .org-name {
        font-size: 1.2em;
        font-weight: bold;
        margin: 5px 0;
      }
      .org-address {
        font-size: 0.7em;
      }
      .form-field {
        margin: 20px 0;
        margin-top: 30px;
      }
      input[type="text"] {
        width: 100%;
        border: none;
        border-bottom: 1px solid #000;
        padding: 5px;
        margin-top: 5px;
      }
      .signature-section {
        display: flex;
        justify-content: space-between;
        margin-top: 50px;
        margin-bottom: 50px;
      }
      .amount-box {
        border: 1px solid #000;
        width: 150px;
        height: 40px;
        margin-top: 20px;
      }
      .footer {
        margin-top: 30px;
        display: flex;
        justify-content: space-between;
        font-size: 0.8em;
      }
      .donation-info {
        text-align: center;
        border: 1px solid #000;
        padding: 5px;
        margin: 10px 0;
        font-size: 0.8em;
      }
      label {
        color: rgb(0, 0, 171);
      }
    </style>
  </head>
  <body>
    <div class="header">
      <div class="logo">
        <img src="http://localhost:3000/images/AnubhutiLogo.png" alt="" />
      </div>
      <div class="org-details">
        <div class="reg-number">
          Registration No. & Date : 11730/09 - 06 May 2009
        </div>
        <div class="org-name">ANUBHUTI VISION SEVA SANSTHAN</div>
        <div class="org-address">
          B.G.-63, Scheme No. 74-C, Vijay Nagar, Indore-452 010 (M.P.)<br />
          Regd. Off. : 203-A, Slice No. 4, Scheme No. 78, Aranya Nagar,<br />
          Indore. Phone: 0731-4050114, Mobile : 98267-44114
        </div>
      </div>
      <div class="receipt-number">
        <div>RECEIPT</div>
        <div>No.: <%= donation.receiptNo %></div>
        <div>Date: <%= new Date(donation.date).toLocaleDateString() %></div>
      </div>
    </div>

    <form>
      <div class="form-field">
        <label>Received with thanks from M/s.</label>
        <input type="text" value="<%= donation.donorName %>" readonly />
      </div>

      <div class="form-field">
        <label>Aadhar Card / PAN No.</label>
        <input type="text" value="<%= donation.pan || 'N/A' %>" readonly />
        <span style="float: right">
          <label>Phone</label>
          <input
            type="text"
            style="width: 200px"
            value="<%= donation.phoneNumber %>"
            readonly
          />
        </span>
      </div>

      <div class="form-field">
        <label>Address</label>
        <input type="text" value="<%= donation.address || 'N/A' %>" readonly />
      </div>

      <div class="form-field">
        <label>The sum of Rs. in words</label>
        <input type="text" value="<%= amountInWords %> /-" readonly />
      </div>

      <div class="form-field">
        <label>By Cash / Cheque / D.D. No.</label>
        <input
          type="text"
          style="width: 60%"
          value="<%= donation.paymentMode %>"
          readonly
        />
        <div>
          <label>Dated</label>
          <input
            type="text"
            style="width: 20%"
            value="<%= new Date(donation.date).toLocaleDateString()  %>"
            readonly
          />
        </div>
      </div>

      <div class="signature-section">
        <div class="amount-box">
          <div style="text-align: center; padding-top: 10px">
            Rs. <%= donation.amount %> /-
          </div>
        </div>
        <!-- <div style="text-align: center">
          <div>................................</div>
          <div>Donor's Signature</div>
        </div> -->
        <div style="text-align: left">
          <div>For : ANUBHUTI VISION SEVA SANSTHAN</div>
          <div style="margin-top: 20px">
            <span style="color: rgb(0, 0, 171)"
              >Accountant / Authorised Person :</span
            >
            <%= (donation.authorizedPersonName).toUpperCase() %>
          </div>
        </div>
      </div>

      <div class="donation-info">
        Donation Exempted U/S 80G of IT ACT<br />
        CIT-I/Ind/Tech/80-G/20/2011-12<br />
        PAN No.: AABAA7262L
      </div>

      <div class="footer">
        <a href="https://www.anubhutivisions.org"
          >Visit us: www.anubhutivisions.org</a
        >
        <a href="mailto:anubhutivisionsss@gmail.com"
          >Contact us: anubhutivisionsss@gmail.com</a
        >
      </div>
    </form>
  </body>
</html>
